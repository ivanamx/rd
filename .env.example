# Clave secreta de Stripe (modo test: sk_test_...)
STRIPE_SECRET_KEY=sk_test_tu_clave_aqui

# Secreto del webhook de Stripe (whsec_...)
# Configura el endpoint: http://localhost:3001/api/stripe-webhook
STRIPE_WEBHOOK_SECRET=whsec_tu_secreto_aqui

# Puerto del servidor (opcional, default 3001)
PORT=3001

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/desierto_sonoro
# DB_NAME=desierto_sonoro
# USE_DB=false  # forzar fallback a archivos JSON
